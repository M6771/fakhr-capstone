# Fakhr — Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)

# API Configuration (required for mobile devices & simulators)
# localhost does NOT work on physical devices or iOS/Android simulators.
# Use your computer's local IP address so the device can reach the backend.
#
# Get your IP:
#   macOS: run "ipconfig getifaddr en0" in Terminal (or en1 if en0 is empty)
#   Windows: run "ipconfig" and use the IPv4 Address of your active adapter
#
EXPO_PUBLIC_API_URL=http://192.168.1.100:8000/api

# Add other environment variables here as needed
